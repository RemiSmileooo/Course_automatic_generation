# 复制本文件为 .env 再填写真实值： copy .env.example .env
# 注意：真实密钥只能写进 .env（已被 .gitignore 忽略），不要写在本模板里！

# ===== LLM (OpenAI-compatible) =====
# 用于课程结构化拆解与口播稿改写。留空则自动使用本地规则兜底（无需联网也能演示）。
OPENAI_API_KEY=
# 可指向任意 OpenAI 兼容网关。OpenAI 官方: https://api.openai.com/v1 ；DeepSeek: https://api.deepseek.com
OPENAI_BASE_URL=https://api.deepseek.com
# OpenAI: gpt-4o-mini ；DeepSeek: deepseek-v4-pro / deepseek-v4-flash
OPENAI_MODEL=deepseek-v4-pro
# Optional: models/gateways that support reasoning_effort can use minimal | low | medium | high.
# If unsupported, the app retries once without this parameter.
OPENAI_REASONING_EFFORT=medium

# ===== MinerU PDF 解析 =====
# 在 https://mineru.net/apiManage 创建 Token。PDF 上传后会先转换为 Markdown，再进入课程生成流程。
MINERU_API_KEY=
MINERU_BASE_URL=https://mineru.net
# 推荐 vlm；也可使用 pipeline
MINERU_MODEL=vlm
MINERU_LANGUAGE=ch
MINERU_OCR=true
MINERU_ENABLE_TABLE=true
MINERU_ENABLE_FORMULA=true
MINERU_TIMEOUT=900
MINERU_POLL_INTERVAL=3
MINERU_UPLOAD_TIMEOUT=180
MINERU_DOWNLOAD_TIMEOUT=180

# ===== TTS =====
# 可选: minimax | edge | offline
# minimax 需要下面的 Key/GroupId；若缺失会自动回退到 edge（免费），再不行回退 offline 静音占位。
TTS_PROVIDER=minimax

# ----- MiniMax Speech -----
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
# 国际站: https://api.minimax.io  | 国内站: https://api.minimax.chat （必须与你 Key 申请的站点一致）
MINIMAX_API_HOST=https://api.minimax.io
# 模型: speech-2.8-turbo / speech-2.8-hd / speech-02-turbo / speech-01-turbo 等
MINIMAX_MODEL=speech-2.8-turbo
# 默认音色 voice_id（仅设默认值；全部可选音色见 src/config.py 的 MINIMAX_VOICES，前端下拉也用它）
# 例如: Chinese (Mandarin)_Gentle_Senior(温柔学姐) / Chinese (Mandarin)_Radio_Host(电台男主播)
MINIMAX_VOICE=Chinese (Mandarin)_Gentle_Senior
MINIMAX_SPEED=1.0

# ----- Edge TTS (免费, 无需 Key) -----
EDGE_VOICE=zh-CN-XiaoxiaoNeural

# ===== 视频参数 =====
# 视觉主题: apple | ink | mint | dark | ocean | violet
THEME=apple
VIDEO_WIDTH=1920
VIDEO_HEIGHT=1080
VIDEO_FPS=24
# 幻灯片渲染器:
#   llm    - LLM 端到端自主设计每页 HTML + 口播稿（默认，需配置 OPENAI_API_KEY；
#            无 Key 或失败时自动回退规则拆课 + 固定模板）
#   html   - 代码内置 HTML 模板渲染
#   pillow - 旧版位图绘制
# 浏览器(Playwright/Edge/Chrome)不可用时统一回退 pillow。
SLIDE_RENDERER=llm
